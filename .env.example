# Discord Bot Token (必須)
# https://discord.com/developers/applications から取得
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (必須)
# Discord Developer Portal の General Information から取得
DISCORD_CLIENT_ID=your_client_id_here

# Gemini API Key (必須)
# https://aistudio.google.com/apikey から無料で取得
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive 認証情報ファイルのパス (オプション)
# Google Cloud Console からサービスアカウントの JSON キーをダウンロード
# Drive 連携が不要な場合は空のままで OK
GOOGLE_CREDENTIALS_PATH=

# Google Drive の共有ドライブ ID (オプション)
# 共有ドライブを使用する場合に設定
GOOGLE_DRIVE_ID=
